@page
@model v2en.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Sign in";
}
<div class="login-wrap">
    <div class="card login-card">
        <h1>Sign in</h1>
        <p class="page-sub" style="text-align:center">v2en admin dashboard</p>

        @if (Model.Error is not null)
        {
            <div class="alert err">@Model.Error</div>
        }

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="field">
                <label asp-for="Username">Username</label>
                <input type="text" asp-for="Username" autocomplete="username" autofocus />
            </div>
            <div class="field">
                <label asp-for="Password">Password</label>
                <input type="password" asp-for="Password" autocomplete="current-password" />
            </div>
            <button class="btn btn-primary" type="submit" style="width:100%; justify-content:center;">Sign in</button>
        </form>
    </div>
</div>
