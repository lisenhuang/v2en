# ---- .NET build output ----
[Bb]in/
[Oo]bj/
[Oo]ut/
[Dd]ebug/
[Rr]elease/
artifacts/
*.user
*.suo
*.userosscache
*.sln.docstates

# ---- .NET / Rider / VS ----
.vs/
*.rsuser
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets

# ---- SQLite database (created at runtime; do not commit) ----
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
/data/

# ---- Secrets / local env ----
# User-secrets live outside the repo (~/.microsoft/usersecrets), so nothing to ignore here,
# but keep local env files out of git just in case.
.env
.env.*
appsettings.*.local.json

# ---- OS noise ----
.DS_Store
Thumbs.db

# ---- VS Code: ignore noise but KEEP shared settings tracked ----
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
